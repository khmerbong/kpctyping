# KPCTyping production environment example
# Never commit a real .env file. Put real values in Render Environment settings.

SECRET_KEY=change-this-to-a-long-random-secret-minimum-32-chars
FLASK_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
BASE_URL=https://your-kpctyping-site.onrender.com
